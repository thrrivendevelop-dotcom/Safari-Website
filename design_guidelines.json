{
  "theme_and_archetype": {
    "domain": "Wildlife Safari Booking",
    "theme": "Hybrid (Light main, Dark footer/admin sidebar)",
    "archetype": "Archetype 1 (Organic & Earthy) + Archetype 5 (Luxury)"
  },
  "typography": {
    "font_families": {
      "heading": "Playfair Display, serif",
      "body": "DM Sans, sans-serif"
    },
    "scale": {
      "h1": "text-5xl sm:text-6xl tracking-tight leading-none",
      "h2": "text-3xl sm:text-4xl tracking-tight leading-tight",
      "h3": "text-xl sm:text-2xl leading-snug",
      "h4": "text-lg sm:text-xl",
      "body_large": "text-lg leading-relaxed",
      "body": "text-base leading-relaxed",
      "small": "text-sm",
      "accent": "text-sm tracking-[0.2em] uppercase"
    },
    "rules": {
      "hero_headline": "text-white font-bold",
      "italic_accent": "text-[var(--brand-amber)] italic",
      "body_text": "text-[var(--text-body)]"
    }
  },
  "colors": {
    "css_variables": {
      "--brand-amber": "#C8860A",
      "--brand-forest": "#1A2B1F",
      "--text-body": "#1C1C1C",
      "--bg-offwhite": "#F9F5EE",
      "--bg-charcoal": "#111111",
      "--bg-white": "#FFFFFF",
      "--tatkal-red": "#E63946",
      "--admin-bg": "#F0EDE8",
      "--price-header": "#000000",
      "--table-row-alt": "#F5F5F5"
    },
    "usage": {
      "primary_cta": "bg-[var(--brand-amber)] text-white font-bold",
      "secondary_cta": "bg-transparent border border-white text-white",
      "hero_overlay": "bg-[#C8860A]/40 mix-blend-multiply",
      "nav_scroll": "bg-[var(--brand-forest)] text-white transition-colors duration-300",
      "nav_transparent": "bg-transparent text-white transition-colors duration-300",
      "tatkal_cta": "bg-[var(--tatkal-red)] text-white animate-pulse"
    }
  },
  "spacing_and_layout": {
    "generous_spacing": "py-24 px-6 md:px-12",
    "section_gap": "gap-12 md:gap-24",
    "card_padding": "p-8",
    "border_radius": "rounded-none md:rounded-sm",
    "container": "max-w-7xl mx-auto"
  },
  "component_patterns": {
    "hero": "Relative container, full height (min-h-screen). Absolute image with amber overlay #C8860A at 40% opacity (bg-[#C8860A]/40). Center aligned massive Playfair heading. Amber italic subtext.",
    "ticker": "Fixed top, bg-[#111111], white text, marquee animation (react-fast-marquee).",
    "navigation": "Sticky/fixed below ticker. Transparent on top, becomes bg-[#1A2B1F] on scroll. Nav items DM Sans. Book Now CTA in bg-[#C8860A].",
    "pricing_table": "Header black #000000 with white text. Rows alternate white and #F5F5F5.",
    "tatkal_section": "Blinking red bg-[#E63946] CTA every 2 seconds. High urgency copy.",
    "cards": "bg-[#F9F5EE]. Subtle hover lift (-translate-y-1) and shadow. Clean borders if any.",
    "faq_accordion": "Clean borders, Playfair questions, DM Sans answers.",
    "floating_whatsapp": "Fixed bottom right, green/amber icon, z-50.",
    "admin_sidebar": "bg-[#1A2B1F], Playfair headings, DM sans links.",
    "admin_cards": "White background, colored left border per stat type."
  },
